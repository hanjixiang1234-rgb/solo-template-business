FROM python:3.11-slim

WORKDIR /app

COPY requirements-openai-cloud-hub.txt /app/requirements-openai-cloud-hub.txt
RUN pip install --no-cache-dir -r /app/requirements-openai-cloud-hub.txt

COPY scripts /app/scripts

ENV MINDER_CLOUD_HOST=0.0.0.0
ENV MINDER_CLOUD_PORT=8787

EXPOSE 8787

CMD ["python", "/app/scripts/openai_cloud_hub_server.py", "--host", "0.0.0.0", "--port", "8787"]
